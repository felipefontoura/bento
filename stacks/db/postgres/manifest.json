{
  "name": "postgres",
  "category": "db",
  "description": "PostgreSQL 15 — apps create their own databases via install scripts",
  "depends_on": [],
  "env": [
    {
      "name": "POSTGRES_PASSWORD",
      "generate": "openssl rand -hex 16",
      "hide": true
    },
    { "name": "POSTGRES_CPU_LIMIT", "default": "0.5" },
    { "name": "POSTGRES_MEM_LIMIT", "default": "256M" }
  ]
}
