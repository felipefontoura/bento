{
  "name": "n8n",
  "category": "app",
  "description": "Workflow automation (editor + worker + webhook)",
  "depends_on": ["postgres", "redis"],
  "env": [
    { "name": "N8N_HOST",          "default": "editor-n8n.${BASE_DOMAIN}",  "prompt": "n8n editor hostname" },
    { "name": "N8N_WEBHOOK_HOST",  "default": "webhook-n8n.${BASE_DOMAIN}", "prompt": "n8n webhook hostname" },
    { "name": "N8N_ENCRYPTION_KEY","generate": "openssl rand -hex 32",  "hide": true },
    { "name": "POSTGRES_PASSWORD", "from_state": "POSTGRES_PASSWORD" },
    { "name": "N8N_EDITOR_CPU_LIMIT", "default": "1" },
    { "name": "N8N_EDITOR_MEM_LIMIT", "default": "768M" },
    { "name": "N8N_WEBHOOK_CPU_LIMIT", "default": "0.5" },
    { "name": "N8N_WEBHOOK_MEM_LIMIT", "default": "512M" },
    { "name": "N8N_WORKER_CPU_LIMIT", "default": "1" },
    { "name": "N8N_WORKER_MEM_LIMIT", "default": "768M" }
  ],
  "post_deploy_url": "https://${N8N_HOST}"
}
