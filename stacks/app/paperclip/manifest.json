{
  "name": "paperclip",
  "category": "app",
  "description": "AI agent orchestration (Claude Code / Codex / OpenCode + Hermes). Installs the hermes_local adapter (@felipefontoura/paperclip-adapter-hermes-local-plus) at deploy time and mounts the hermes-bin volume cross-stack so the plugin can spawn `hermes chat` as a subprocess. Provider API keys are operator-supplied via Portainer at day-2.",
  "depends_on": ["postgres"],
  "env": [
    { "name": "PAPERCLIP_HOST",     "default": "paperclip.${BASE_DOMAIN}", "prompt": "Paperclip hostname" },
    { "name": "BETTER_AUTH_SECRET", "generate": "openssl rand -hex 32",    "hide": true },
    { "name": "POSTGRES_PASSWORD",  "from_state": "POSTGRES_PASSWORD", "prompt": "Postgres password", "hide": true, "default": "" },
    { "name": "OPENAI_API_KEY",     "from_state": "OPENAI_API_KEY",     "prompt": "OpenAI API key (optional)",     "hide": true, "default": "" },
    { "name": "ANTHROPIC_API_KEY",  "from_state": "ANTHROPIC_API_KEY",  "prompt": "Anthropic API key (optional)",  "hide": true, "default": "" },
    { "name": "OPENROUTER_API_KEY", "from_state": "OPENROUTER_API_KEY", "prompt": "OpenRouter API key (optional)", "hide": true, "default": "" }
  ],
  "post_deploy_url": "https://${PAPERCLIP_HOST}"
}
