#!/bin/bash
# bento-auth — register AI-provider API keys and propagate them
#
# Scope: CLASSIC API KEYS ONLY. You paste a provider API key, bento-auth
# validates it (where possible), stores it in ~/.config/bento/state.json under
# `providers.<ENV_VAR>`, and propagates it to every running BENTO_MANAGED stack
# (and to all future deploys via lib/stacks.sh::stacks_build_env_payload).
#
# Subscriptions (Claude Pro/Max, ChatGPT Plus) are intentionally OUT OF SCOPE:
# they are OAuth and are far better handled by each app's NATIVE sign-in, which
# refreshes the token properly — e.g. openclaw `models auth login`, paperclip's
# bundled CLI logins (`claude /login`, `opencode auth login`). bento-auth's old
# env-snapshot approach went stale in ~10 days and is gone.
#
# Usage:
#   bento-auth                     interactive picker
#   bento-auth <provider>          register an API key (catalog providers)
#   bento-auth openai-compat <label> <base_url>
#                                  register any OpenAI-compatible endpoint
#   bento-auth list                show registered provider keys (masked)
#   bento-auth --help              this help
#
# Environment:
#   BENTO_REPO_ROOT        clone path (default /root/.local/share/bento)
#   BENTO_AUTH_ASSUME_YES  skip the "store anyway?" prompt on failed validation
#
# Providers are declared as data in lib/provider-catalog.json — adding one is a
# JSON edit, not a code change.

set -uo pipefail

# -----------------------------------------------------------------------------
# Bootstrap
# -----------------------------------------------------------------------------

# Locate the bento repo root so we can source helpers. boot.sh clones to
# /root/.local/share/bento by default; honour an override so contributors can
# dogfood from a working clone.
BENTO_REPO_ROOT="${BENTO_REPO_ROOT:-/root/.local/share/bento}"
if [[ ! -d "$BENTO_REPO_ROOT/lib" ]]; then
    BENTO_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

# shellcheck source=../lib/auth-helpers.sh
source "$BENTO_REPO_ROOT/lib/auth-helpers.sh"

# Lightweight ui helpers — no gum dependency so bento-auth runs from cron / SSH.
_color() { printf '\033[%sm%s\033[0m' "$1" "$2"; }
_info()  { printf '%s %s\n' "$(_color 36 'ℹ')" "$*"; }
_warn()  { printf '%s %s\n' "$(_color 33 '⚠')" "$*" >&2; }
_ok()    { printf '%s %s\n' "$(_color 32 '✓')" "$*"; }
_err()   { printf '%s %s\n' "$(_color 31 '✗')" "$*" >&2; }

# -----------------------------------------------------------------------------
# Shared: persist + propagate
# -----------------------------------------------------------------------------

# Store a key (+ optional base URL) in state.providers and propagate to every
# BENTO_MANAGED stack. Shared by catalog providers and the ad-hoc command.
_register_api_key() {
    local label="$1" env="$2" key="$3" base_url="${4:-}" base_url_env="${5:-OPENAI_BASE_URL}"

    _info "Persisting ${env} to bento state..."
    auth_state_providers_set "$env" "$key"
    if [[ -n "$base_url" ]]; then
        auth_state_providers_set "$base_url_env" "$base_url"
    fi

    _info "Propagating to every running BENTO_MANAGED stack..."
    auth_propagate_state_providers

    _ok "${label} registered. Present and future bento stacks inherit it."
}

# -----------------------------------------------------------------------------
# bento-auth <provider> — catalog-driven API-key registration
# -----------------------------------------------------------------------------

cmd_api_key() {
    local id="$1"
    if ! auth_catalog_has "$id"; then
        _err "Unknown provider: $id"
        return 2
    fi

    local label env base_url base_url_env signup_url validate_url note
    label=$(auth_catalog_get "$id" label)
    env=$(auth_catalog_get "$id" env)
    base_url=$(auth_catalog_get "$id" base_url)
    base_url_env=$(auth_catalog_get "$id" base_url_env)
    signup_url=$(auth_catalog_get "$id" signup_url)
    validate_url=$(auth_catalog_get "$id" validate_url)
    note=$(auth_catalog_get "$id" note)

    printf '\n'
    _info "Register API key — ${label}"
    [[ -n "$note" ]] && printf '  %s\n' "$note"
    [[ -n "$signup_url" ]] && _info "Get a key at: ${signup_url}"
    if [[ -n "$base_url" ]]; then
        _info "OpenAI-compatible endpoint: ${base_url}"
        _info "Stored in its OWN slot (${env} + ${base_url_env}) — coexists with"
        _info "  every other provider. Wire it in your app as a custom provider:"
        _info "    apiKey = \${${env}}   baseUrl = \${${base_url_env}}"
    fi

    printf 'Paste the API key (input hidden): '
    local key
    read -rs key
    printf '\n'
    if [[ -z "$key" ]]; then
        _err "No key entered. Aborted."
        return 1
    fi

    if [[ -n "$validate_url" ]]; then
        _info "Validating against ${validate_url} ..."
        auth_validate_api_key "$validate_url" "$key"
        case $? in
            0) _ok "Key accepted by ${label}." ;;
            2) _warn "Skipped validation (curl missing) — storing anyway." ;;
            *)
                _warn "Validation FAILED — key rejected or endpoint unreachable."
                if [[ "${BENTO_AUTH_ASSUME_YES:-0}" != "1" ]]; then
                    printf 'Store it anyway? [y/N] '
                    local reply
                    read -r reply
                    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
                        _info "Aborted. No changes made."
                        return 1
                    fi
                fi
                ;;
        esac
    fi

    _register_api_key "$label" "$env" "$key" "$base_url" "${base_url_env:-OPENAI_BASE_URL}"
}

# -----------------------------------------------------------------------------
# bento-auth openai-compat <label> <base_url> — ad-hoc OpenAI-compatible endpoint
# -----------------------------------------------------------------------------

cmd_openai_compat() {
    local label="${1:-}" base_url="${2:-}"
    if [[ -z "$label" || -z "$base_url" ]]; then
        _err "Usage: bento-auth openai-compat <label> <base_url>"
        _info "Example: bento-auth openai-compat my-llm https://api.example.com/v1"
        _info "For known providers (z.ai, kimi, qwen, …) use their named subcommand —"
        _info "  this is only for exotic / one-off endpoints not in the catalog."
        return 2
    fi

    printf '\n'
    _info "Register exotic OpenAI-compatible endpoint — ${label} (${base_url})"
    _warn "This is the SHARED OpenAI slot (OPENAI_API_KEY + OPENAI_BASE_URL) —"
    _warn "  it REPLACES any other occupant. For a provider that must coexist,"
    _warn "  add it to lib/provider-catalog.json with a dedicated env instead."

    printf 'Paste the API key (input hidden): '
    local key
    read -rs key
    printf '\n'
    if [[ -z "$key" ]]; then
        _err "No key entered. Aborted."
        return 1
    fi

    _info "Validating against ${base_url%/}/models ..."
    auth_validate_api_key "${base_url%/}/models" "$key"
    case $? in
        0) _ok "Key accepted." ;;
        2) _warn "Skipped validation (curl missing) — storing anyway." ;;
        *)
            _warn "Validation FAILED (the endpoint may not expose /models)."
            if [[ "${BENTO_AUTH_ASSUME_YES:-0}" != "1" ]]; then
                printf 'Store it anyway? [y/N] '
                local reply
                read -r reply
                if [[ ! "$reply" =~ ^[Yy]$ ]]; then
                    _info "Aborted. No changes made."
                    return 1
                fi
            fi
            ;;
    esac

    _register_api_key "$label" "OPENAI_API_KEY" "$key" "$base_url" "OPENAI_BASE_URL"
}

# -----------------------------------------------------------------------------
# bento-auth list — show registered provider keys (from state.providers, masked)
# -----------------------------------------------------------------------------

cmd_list() {
    local any=0 var val masked extra=""
    while IFS=$'\t' read -r var val; do
        [[ -z "$var" ]] && continue
        # Base URLs are not secrets — show them in full at the end.
        if [[ "$var" == *BASE_URL ]]; then
            extra="${extra}
  ${var} = ${val}"
            continue
        fi
        if (( any == 0 )); then
            printf '%-26s %s\n' "provider env" "value (masked)"
            printf '%-26s %s\n' "------------" "--------------"
            any=1
        fi
        masked="${val:0:6}…${val: -4}"
        printf '%-26s %s\n' "$var" "$masked"
    done < <(auth_state_providers_dump)

    if (( any == 0 )); then
        _info "No provider keys registered yet. Run 'bento-auth <provider>' to add one."
    fi
    [[ -n "$extra" ]] && printf '\nbase URLs:%s\n' "$extra"
}

# -----------------------------------------------------------------------------
# Interactive picker
# -----------------------------------------------------------------------------

cmd_interactive() {
    cat <<'BANNER'

bento-auth — register an AI provider API key

Pick a provider to register a classic API key. Set once → propagated to every
BENTO_MANAGED stack that reads it. (Subscriptions use each app's native sign-in.)

BANNER

    local -a ids=() labels=()
    local cid clabel
    while IFS=$'\t' read -r cid clabel _; do
        [[ -z "$cid" ]] && continue
        ids+=("$cid"); labels+=("$clabel")
    done < <(auth_catalog_list)
    ids+=("__list__"); labels+=("List registered keys")
    ids+=("__quit__"); labels+=("Quit")

    PS3=$'\nProvider: '
    local choice
    select choice in "${labels[@]}"; do
        local idx=$(( REPLY - 1 ))
        if (( idx < 0 || idx >= ${#ids[@]} )); then
            _warn "Invalid choice. Try again."
            continue
        fi
        case "${ids[$idx]}" in
            __list__) cmd_list; break ;;
            __quit__) return 0 ;;
            *)        cmd_api_key "${ids[$idx]}"; break ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Help
# -----------------------------------------------------------------------------

cmd_help() {
    cat <<'HELP'
bento-auth — register AI-provider API keys and propagate them

Usage:
  bento-auth                     interactive picker
  bento-auth <provider>          register an API key (see list below)
  bento-auth openai-compat <label> <base_url>
                                 register any OpenAI-compatible endpoint
  bento-auth list                show registered provider keys (masked)
  bento-auth --help              this help

HELP

    printf 'Providers (from lib/provider-catalog.json):\n'
    local cid clabel cfmt
    while IFS=$'\t' read -r cid clabel cfmt; do
        [[ -z "$cid" ]] && continue
        printf '  %-12s %s (%s)\n' "$cid" "$clabel" "$cfmt"
    done < <(auth_catalog_list)

    cat <<'HELP'

Environment:
  BENTO_REPO_ROOT       override clone path (default /root/.local/share/bento)
  BENTO_AUTH_ASSUME_YES skip the "store anyway?" prompt on failed validation

Subscriptions (Claude Pro/Max, ChatGPT Plus) are OUT OF SCOPE — they are OAuth
and are handled by each app's native sign-in (which refreshes properly), e.g.
openclaw `models auth login`, paperclip's bundled CLI logins.

See docs/reference/bento-auth.md for the full picture.
HELP
}

# -----------------------------------------------------------------------------
# Entry point
# -----------------------------------------------------------------------------

main() {
    local cmd="${1:-}"
    case "$cmd" in
        ""|interactive)  cmd_interactive ;;
        openai-compat)   shift; cmd_openai_compat "$@" ;;
        list)            cmd_list ;;
        -h|--help|help)  cmd_help ;;
        *)
            if auth_catalog_has "$cmd"; then
                cmd_api_key "$cmd"
            else
                _err "Unknown subcommand: $cmd"
                cmd_help
                exit 2
            fi
            ;;
    esac
}

main "$@"
