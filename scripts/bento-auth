#!/bin/bash
# bento-auth — interactive OAuth + API-key login for AI providers
#
# Wraps the device-flow login of each provider that the paperclip image
# already ships (claude, codex/opencode), persists the resulting token
# into the paperclip swarm service so the Hermes runtime picks it up,
# and surfaces the relevant commercial gotchas BEFORE the user spends
# a credit they didn't budget for.
#
# Usage:
#   bento-auth                     interactive picker
#   bento-auth claude              login Claude (Anthropic) via OAuth
#   bento-auth openai-codex        login ChatGPT Plus -> Codex via OAuth
#   bento-auth list                show authenticated providers + expiry
#   bento-auth status <provider>   exit non-zero if token expired
#   bento-auth --help              this help
#
# Environment:
#   BENTO_REPO_ROOT   default /root/.local/share/bento
#                     used to locate lib/auth-helpers.sh
#   BENTO_AUTH_ASSUME_YES=1
#                     skip the commercial-policy confirm prompt for claude
#                     (you accepted it in writing somewhere else)
#
# Designed assumption: this script runs on the VPS host, NOT inside the
# paperclip container. It uses `docker exec` to drive the per-provider
# CLI that ships with the paperclip image.
#
# Compatible providers (MVP):
#   - claude         (Anthropic OAuth, Claude Pro/Max subscription)
#                    NOTE: Anthropic moved third-party apps OFF the
#                    Pro/Max quota. Inference via Hermes consumes "extra
#                    usage" (pay-as-you-go) — see the warning below.
#   - openai-codex   (ChatGPT Plus OAuth -> Codex; gpt-5.4 only model
#                    accepted on Plus subscription)
#
# Out of scope here (MVP — track in repo issues):
#   - auto-refresh cron      see issue #19
#   - web UI                 future, after CLI proves the model
#   - other OAuth providers  (gemini, qwen, etc.) — add when requested

set -uo pipefail

# -----------------------------------------------------------------------------
# Bootstrap
# -----------------------------------------------------------------------------

# Locate the bento repo root so we can source helpers. boot.sh clones to
# /root/.local/share/bento by default; honour an override so contributors
# can dogfood from a working clone.
BENTO_REPO_ROOT="${BENTO_REPO_ROOT:-/root/.local/share/bento}"
if [[ ! -d "$BENTO_REPO_ROOT/lib" ]]; then
    # Fall back to the directory containing this script (covers running
    # from `~/Work/quickstack/scripts/bento-auth` during local dev).
    BENTO_REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

# shellcheck source=../lib/auth-helpers.sh
source "$BENTO_REPO_ROOT/lib/auth-helpers.sh"

# Lightweight ui_*-equivalent helpers — we don't require gum here because
# bento-auth must also be runnable from one-line cron / SSH oneliners.
_color() { printf '\033[%sm%s\033[0m' "$1" "$2"; }
_info()  { printf '%s %s\n' "$(_color 36 'ℹ')" "$*"; }
_warn()  { printf '%s %s\n' "$(_color 33 '⚠')" "$*" >&2; }
_ok()    { printf '%s %s\n' "$(_color 32 '✓')" "$*"; }
_err()   { printf '%s %s\n' "$(_color 31 '✗')" "$*" >&2; }

# -----------------------------------------------------------------------------
# Commercial policy warning — Anthropic
# -----------------------------------------------------------------------------

# Displayed once per `bento-auth claude` invocation, ahead of the device
# flow. Set BENTO_AUTH_ASSUME_YES=1 to skip the confirm prompt — the
# warning still PRINTS, because the rule is "no surprise bills", not
# "no friction". Operators who automate this script should pin
# BENTO_AUTH_ASSUME_YES in their orchestration and document it.
_print_anthropic_warning() {
    cat <<'WARN'

═══════════════════════════════════════════════════════════════
 Login: Anthropic (Claude) via OAuth
═══════════════════════════════════════════════════════════════

 This logs your Claude Pro/Max subscription into the paperclip
 container so the Hermes runtime can call Claude models for
 your agents.

 IMPORTANT — billing reality (verified 2026-06-08):

   Anthropic moved third-party apps OFF the Pro/Max quota.
   When Hermes (or any non-Claude-Code app) calls /v1/messages
   with this OAuth token, it consumes "extra usage" credits,
   NOT your monthly Pro/Max allowance.

   Inference will fail with HTTP 400 until you load credits:
     -> https://claude.ai/settings/usage

   Cost is the same per-token rate as the public API. Your
   Pro/Max plan still covers the `claude` CLI itself when
   invoked directly — only third-party callers like Hermes
   are routed to extra usage.

   Your call. This script wires the token either way.

WARN
}

# -----------------------------------------------------------------------------
# Subcommand: bento-auth claude
# -----------------------------------------------------------------------------

cmd_claude() {
    _print_anthropic_warning

    if [[ "${BENTO_AUTH_ASSUME_YES:-0}" != "1" ]]; then
        printf 'Continue? [y/N] '
        local reply
        read -r reply
        if [[ ! "$reply" =~ ^[Yy]$ ]]; then
            _info "Cancelled. No changes made."
            return 0
        fi
    fi

    local cid
    if ! cid=$(auth_find_paperclip_container); then
        _err "paperclip container not running. Deploy the paperclip stack via Step 3 first."
        return 1
    fi

    _info "Launching device-flow login inside the paperclip container..."
    _info "You'll be given a URL to open in your browser — paste the code back here."

    # `claude login` reads from stdin (the device-flow code), writes the
    # device URL to stdout, and persists ~/.claude/.credentials.json on
    # success. -i (interactive) + -t (tty) keeps the prompt rendering
    # correctly across docker exec.
    if ! sudo docker exec -it --user node -e HOME=/paperclip "$cid" claude /login; then
        _err "claude /login failed. Re-run after fixing the issue."
        return 1
    fi

    # Extract the freshly-minted access token from the credentials JSON
    # the CLI just wrote, then wire it into the service env as
    # CLAUDE_CODE_OAUTH_TOKEN. Hermes auto-detects OAuth tokens by the
    # sk-ant-oat prefix and routes them via Bearer + Claude Code headers.
    local token
    token=$(sudo docker exec --user node "$cid" \
        sh -c "jq -r '.claudeAiOauth.accessToken // empty' ${AUTH_CLAUDE_CREDENTIALS_PATH_IN_CONTAINER} 2>/dev/null") || true
    if [[ -z "$token" ]]; then
        _err "claude /login appeared to succeed but no token was written to ${AUTH_CLAUDE_CREDENTIALS_PATH_IN_CONTAINER}."
        return 1
    fi

    _info "Persisting CLAUDE_CODE_OAUTH_TOKEN to bento state..."
    auth_state_providers_set "CLAUDE_CODE_OAUTH_TOKEN" "$token"
    # OAuth and API key for Anthropic are mutually exclusive — they
    # trigger the dual-header trap if both are set. Drop the other
    # before propagating the new value.
    auth_state_providers_unset "ANTHROPIC_API_KEY"

    _info "Propagating to every running BENTO_MANAGED stack..."
    auth_propagate_state_providers "ANTHROPIC_API_KEY"

    _ok   "Claude OAuth registered. Every present and future bento stack will inherit it."
    _info "Test inside the paperclip container:"
    printf '  docker exec --user node -e HOME=/paperclip %s \\\n' "$(printf '%.12s' "$cid")"
    printf '    /opt/hermes/bin/hermes chat -q "ping" -Q --provider anthropic --model claude-haiku-4-5\n'
    _info "Expect HTTP 400 with 'extra usage' until you load credits at https://claude.ai/settings/usage."
}

# -----------------------------------------------------------------------------
# Subcommand: bento-auth openai-codex
# -----------------------------------------------------------------------------

cmd_openai_codex() {
    cat <<'INFO'

═══════════════════════════════════════════════════════════════
 Login: OpenAI Codex (ChatGPT Plus) via OAuth
═══════════════════════════════════════════════════════════════

 This logs your ChatGPT Plus subscription into the paperclip
 container so the Hermes runtime can call Codex models for
 your agents.

 Billing: as of 2026-06-08, the ChatGPT Plus subscription
 ($20/month) still covers Codex calls from third-party clients
 within the standard Plus rate limits. Only the gpt-5.4 model
 is accepted on the Plus tier (other ids return HTTP 400).

INFO

    local cid
    if ! cid=$(auth_find_paperclip_container); then
        _err "paperclip container not running. Deploy the paperclip stack via Step 3 first."
        return 1
    fi

    _info "Launching device-flow login inside the paperclip container (opencode auth login)..."
    _info "You'll be given a URL to open in your browser — paste the code back here."

    if ! sudo docker exec -it --user node -e HOME=/paperclip "$cid" \
        opencode auth login openai; then
        _err "opencode auth login openai failed. Re-run after fixing the issue."
        return 1
    fi

    local token
    token=$(sudo docker exec --user node "$cid" \
        sh -c "jq -r '.openai.access // empty' ${AUTH_OPENCODE_PATH_IN_CONTAINER} 2>/dev/null") || true
    if [[ -z "$token" ]]; then
        _err "opencode auth login appeared to succeed but no token was written to ${AUTH_OPENCODE_PATH_IN_CONTAINER}."
        return 1
    fi

    _info "Persisting OPENAI_API_KEY to bento state..."
    auth_state_providers_set "OPENAI_API_KEY" "$token"

    _info "Propagating to every running BENTO_MANAGED stack..."
    auth_propagate_state_providers

    # Live-register with Hermes on paperclip without waiting for the
    # service-update restart cycle to swap envs in.
    sudo docker exec --user node -e HOME=/paperclip "$cid" \
        /opt/hermes/bin/hermes auth add openai-codex \
            --type api-key --api-key "$token" --label "chatgpt-plus" >/dev/null 2>&1 || true

    _ok   "OpenAI Codex OAuth registered. Every present and future bento stack will inherit it."
    _info "Test inside the paperclip container:"
    printf '  docker exec --user node -e HOME=/paperclip %s \\\n' "$(printf '%.12s' "$cid")"
    printf '    /opt/hermes/bin/hermes chat -q "ping" -Q --provider openai-codex --model gpt-5.4\n'
}

# -----------------------------------------------------------------------------
# Subcommand: bento-auth list
# -----------------------------------------------------------------------------

cmd_list() {
    local cid
    if ! cid=$(auth_find_paperclip_container); then
        _warn "paperclip container not running. Nothing to list."
        return 1
    fi

    printf '%-16s %-12s %-30s %s\n' "provider" "source" "expires" "subject"
    printf '%-16s %-12s %-30s %s\n' "--------" "------" "-------" "-------"

    # Anthropic / claude — read claudeAiOauth from credentials.json
    local claude_blob
    claude_blob=$(sudo docker exec --user node "$cid" \
        sh -c "cat ${AUTH_CLAUDE_CREDENTIALS_PATH_IN_CONTAINER} 2>/dev/null") || true
    if [[ -n "$claude_blob" ]]; then
        local claude_exp claude_label
        claude_exp=$(printf '%s' "$claude_blob" | jq -r '.claudeAiOauth.expiresAt // empty' 2>/dev/null)
        claude_label=$(auth_format_relative_expiry "$claude_exp")
        printf '%-16s %-12s %-30s %s\n' "claude" "claude-cli" "$claude_label" "(Anthropic OAuth)"
    fi

    # Codex / openai — read opencode auth.json
    local opencode_blob
    opencode_blob=$(sudo docker exec --user node "$cid" \
        sh -c "cat ${AUTH_OPENCODE_PATH_IN_CONTAINER} 2>/dev/null") || true
    if [[ -n "$opencode_blob" ]]; then
        local openai_access openai_exp openai_label
        openai_access=$(printf '%s' "$opencode_blob" | jq -r '.openai.access // empty' 2>/dev/null)
        if [[ -n "$openai_access" ]]; then
            openai_exp=$(auth_decode_jwt_exp "$openai_access" || echo "")
            openai_label=$(auth_format_relative_expiry "$openai_exp")
            printf '%-16s %-12s %-30s %s\n' "openai-codex" "opencode" "$openai_label" "(ChatGPT Plus OAuth)"
        fi
    fi
}

# -----------------------------------------------------------------------------
# Subcommand: bento-auth status <provider>
# -----------------------------------------------------------------------------

cmd_status() {
    local provider="${1:-}"
    if [[ -z "$provider" ]] || ! auth_is_supported_provider "$provider"; then
        _err "Usage: bento-auth status <claude|openai-codex>"
        return 2
    fi

    local cid
    if ! cid=$(auth_find_paperclip_container); then
        _err "paperclip container not running."
        return 3
    fi

    case "$provider" in
        claude)
            local exp
            exp=$(sudo docker exec --user node "$cid" \
                sh -c "jq -r '.claudeAiOauth.expiresAt // empty' ${AUTH_CLAUDE_CREDENTIALS_PATH_IN_CONTAINER} 2>/dev/null") || true
            if [[ -z "$exp" ]]; then
                _err "No Claude credentials present."
                return 4
            fi
            local now_ms
            now_ms=$(( $(date +%s) * 1000 ))
            if (( exp < now_ms )); then
                _warn "Claude OAuth EXPIRED ($(auth_format_relative_expiry "$exp"))"
                return 5
            fi
            _ok "Claude OAuth $(auth_format_relative_expiry "$exp")"
            ;;
        openai-codex)
            local access exp
            access=$(sudo docker exec --user node "$cid" \
                sh -c "jq -r '.openai.access // empty' ${AUTH_OPENCODE_PATH_IN_CONTAINER} 2>/dev/null") || true
            if [[ -z "$access" ]]; then
                _err "No Codex credentials present."
                return 4
            fi
            if ! exp=$(auth_decode_jwt_exp "$access"); then
                _warn "Codex token present but expiry could not be decoded."
                return 5
            fi
            local now_iso
            now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
            if [[ "$exp" < "$now_iso" ]]; then
                _warn "Codex OAuth EXPIRED ($(auth_format_relative_expiry "$exp"))"
                return 5
            fi
            _ok "Codex OAuth $(auth_format_relative_expiry "$exp")"
            ;;
    esac
}

# -----------------------------------------------------------------------------
# Interactive picker
# -----------------------------------------------------------------------------

cmd_interactive() {
    cat <<'BANNER'

bento-auth — interactive provider login

Pick a provider to log into. You can re-run this any time to add more
or refresh expired tokens.

BANNER

    PS3=$'\nProvider: '
    local choice
    select choice in \
        "Claude (Anthropic, Pro/Max)" \
        "OpenAI Codex (ChatGPT Plus)" \
        "List authenticated providers" \
        "Quit"
    do
        case "$REPLY" in
            1) cmd_claude;       break ;;
            2) cmd_openai_codex; break ;;
            3) cmd_list;         break ;;
            4) return 0 ;;
            *) _warn "Invalid choice. Try again." ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Help
# -----------------------------------------------------------------------------

cmd_help() {
    cat <<'HELP'
bento-auth — interactive OAuth + API-key login for AI providers

Usage:
  bento-auth                     interactive picker
  bento-auth claude              login Claude (Anthropic) via OAuth
  bento-auth openai-codex        login ChatGPT Plus -> Codex via OAuth
  bento-auth list                show authenticated providers + expiry
  bento-auth status <provider>   exit 0 if valid, non-zero if missing/expired
  bento-auth --help              this help

Environment:
  BENTO_REPO_ROOT       override clone path (default /root/.local/share/bento)
  BENTO_AUTH_ASSUME_YES skip the Anthropic commercial-policy confirm prompt

Exit codes (for `bento-auth status`):
  0  token present and valid
  2  bad usage
  3  paperclip container not running
  4  no credentials for that provider
  5  token expired

See docs/reference/bento-auth.md for the full picture.
HELP
}

# -----------------------------------------------------------------------------
# Entry point
# -----------------------------------------------------------------------------

main() {
    local cmd="${1:-}"
    case "$cmd" in
        ""|interactive)     cmd_interactive ;;
        claude)             cmd_claude ;;
        openai-codex|codex) cmd_openai_codex ;;
        list)               cmd_list ;;
        status)             shift; cmd_status "$@" ;;
        -h|--help|help)     cmd_help ;;
        *)                  _err "Unknown subcommand: $cmd"; cmd_help; exit 2 ;;
    esac
}

main "$@"
